         "@xla//xla/tsl/framework:metrics",
+        "//tensorflow/core/framework:kernel_shape_util",
+        "//tensorflow/core/lib/wav:wav_io",
+        "@xla//xla/tsl/lib/monitoring:percentile_sampler",
         "//tensorflow/core/data:captured_function",
